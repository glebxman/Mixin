# ─── Database ────────────────────────────────────────────────
# Never commit real credentials. Values here are dev defaults / placeholders.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mixin_dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mixin_dev

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────
# Required in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── AI (OpenRouter — OpenAI-compatible API) ─────────────────
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=replace-with-strong-random-value
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Set to a valid OpenRouter image model id; default below is a free preview.
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image-preview:free

# AI rate limiting. Must remain "false" in production so abuse-prevention stays on.
AI_RATE_LIMIT_DISABLED=false

# Daily AI message thresholds per subscription plan. Must be positive integers.
AI_FREE_MESSAGES_PER_DAY=50
AI_BASIC_MESSAGES_PER_DAY=200
AI_PREMIUM_MESSAGES_PER_DAY=2000

# ─── Google OAuth (sign in with Google) ──────────────────────
# Google Cloud Console redirect URI:
#   http://localhost:3001/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=change-me
GOOGLE_OAUTH_CLIENT_SECRET=change-me
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
API_PUBLIC_URL=http://localhost:3001

# ─── Qdrant ──────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=change-me
QDRANT_COLLECTION=textbooks

# ─── Embeddings (used by scripts/process_textbooks.py) ───────
# Backend for vectorising textbook chunks before indexing.
#   local  — sentence-transformers, runs offline on CPU/GPU
#   google — Gemini text-embedding-004 via google-generativeai
EMBEDDING_BACKEND=local
EMBEDDING_MODEL_LOCAL=intfloat/multilingual-e5-base
# Vector dimensionality. Must match the chosen model:
#   intfloat/multilingual-e5-base   → 768
#   intfloat/multilingual-e5-small  → 384
#   BAAI/bge-m3                     → 1024
#   text-embedding-004 (google)     → 768
EMBEDDING_VECTOR_SIZE=768
# Only required when EMBEDDING_BACKEND=google
GOOGLE_AI_API_KEY=

# ─── ClickHouse ──────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=edtech_analytics

# ─── Storage (S3-compatible) ─────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET=edtech-media

# ─── Kundalik.uz ─────────────────────────────────────────────
KUNDALIK_API_URL=https://api.kundalik.uz
KUNDALIK_API_KEY=change-me

# ─── Payments: Payme ─────────────────────────────────────────
PAYME_MERCHANT_ID=change-me
PAYME_SECRET_KEY=change-me
PAYME_TEST_SECRET_KEY=change-me

# ─── Payments: Uzum Pay ──────────────────────────────────────
UZUM_MERCHANT_ID=change-me
UZUM_SECRET_KEY=change-me

# ─── Internal services ───────────────────────────────────────
NODE_ENV=development
API_PORT=3001
AI_SERVICE_URL=http://localhost:8000
ANALYTICS_SERVICE_URL=http://localhost:3002
INTEGRATIONS_SERVICE_URL=http://localhost:3003

# Internal token for API → AI service requests. AI rejects requests without it.
INTERNAL_SERVICE_TOKEN=replace-with-strong-random-value

# ─── Public URLs (frontend) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_URL=http://localhost:8000
NEXT_PUBLIC_STUDENT_URL=http://localhost:3100
NEXT_PUBLIC_PARENT_URL=http://localhost:3200
NEXT_PUBLIC_SCHOOL_URL=http://localhost:3300
NEXT_PUBLIC_ADMIN_URL=http://localhost:3400

VITE_API_URL=http://localhost:3001
VITE_AI_URL=http://localhost:8000
VITE_STUDENT_URL=http://localhost:3100
VITE_PARENT_URL=http://localhost:3200
VITE_SCHOOL_URL=http://localhost:3300
VITE_ADMIN_URL=http://localhost:3400
