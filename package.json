{
  "name": "edtech-uz",
  "private": true,
  "//": "scripts.dev/scripts.build exclude @edtech/analytics and @edtech/integrations because they are placeholder stub services (see services/analytics/README.md and services/integrations/README.md). Turbo 2 does not support a task-level `filter` key in turbo.json, so the exclusion is expressed via CLI --filter flags here.",
  "scripts": {
    "dev": "turbo run dev --filter=!@edtech/analytics --filter=!@edtech/integrations",
    "build": "turbo run build --filter=!@edtech/analytics --filter=!@edtech/integrations",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @edtech/db generate",
    "db:migrate": "pnpm --filter @edtech/db migrate",
    "db:push": "pnpm --filter @edtech/db push",
    "prepare": "husky",
    "lint:root": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  }
}
